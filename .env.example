# ---------------------------------------------------------------------------
# Modèle de configuration pour Jàkkaarloo.
# Copiez ce fichier en « .env » puis renseignez vos valeurs.
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)
#
# ⚠️  NE JAMAIS committer le fichier .env réel : il est ignoré par .gitignore.
#     Aucune clé/secret ne doit apparaître dans le code source.
# ---------------------------------------------------------------------------

# --- Authentification Gemini (OBLIGATOIRE) ---------------------------------
# Clé API obtenue sur https://aistudio.google.com/app/apikey
# Laissez FALSE pour utiliser l'API Gemini publique avec GOOGLE_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=votre_cle_gemini_ici

# --- Modèle utilisé par tous les agents ------------------------------------
# gemini-3.5-flash : multimodal (texte + image), rapide et économique.
# Il gère le chat texte ET le diagnostic par photo.
JAKKAARLOO_MODEL=gemini-3.5-flash

# --- Serveur MCP « marché agricole » ---------------------------------------
# URL du endpoint MCP (transport streamable-http). Doit se terminer par /mcp.
MCP_MARKET_URL=http://localhost:8080/mcp
